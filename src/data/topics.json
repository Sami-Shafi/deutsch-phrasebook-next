[
  {
    "id": 1,
    "icon": "ti-user",
    "name": "Personal Info",
    "sub": "Sich vorstellen — Introducing yourself",
    "groups": [
      {
        "title": "Basic introductions",
        "phrases": [
          {
            "de": "Wie heißen Sie? / Wie heißt du?",
            "en": "What is your name? (formal / informal)"
          },
          {
            "de": "Ich heiße Sami.",
            "en": "My name is Sami."
          },
          {
            "de": "Ich bin Sami.",
            "en": "I am Sami."
          },
          {
            "de": "Wie alt sind Sie? / Wie alt bist du?",
            "en": "How old are you? (formal / informal)"
          },
          {
            "de": "Ich bin 25 Jahre alt.",
            "en": "I am 25 years old."
          },
          {
            "de": "Woher kommen Sie? / Woher kommst du?",
            "en": "Where are you from?"
          },
          {
            "de": "Ich komme aus Bangladesch.",
            "en": "I come from Bangladesh."
          },
          {
            "de": "Ich bin aus Khulna.",
            "en": "I am from Khulna."
          }
        ]
      },
      {
        "title": "Where you live",
        "phrases": [
          {
            "de": "Wo wohnen Sie? / Wo wohnst du?",
            "en": "Where do you live?"
          },
          {
            "de": "Ich wohne in Dhaka.",
            "en": "I live in Dhaka."
          },
          {
            "de": "Meine Adresse ist ...",
            "en": "My address is ..."
          }
        ]
      },
      {
        "title": "Contact & numbers",
        "phrases": [
          {
            "de": "Wie ist Ihre Telefonnummer?",
            "en": "What is your phone number?"
          },
          {
            "de": "Meine Nummer ist ...",
            "en": "My number is ..."
          },
          {
            "de": "Wie ist Ihre E-Mail-Adresse?",
            "en": "What is your email address?"
          },
          {
            "de": "Können Sie das buchstabieren?",
            "en": "Can you spell that?"
          }
        ]
      },
      {
        "title": "Nationality & language",
        "phrases": [
          {
            "de": "Ich bin Bangladescher / Bangladescherin.",
            "en": "I am Bangladeshi (m/f)."
          },
          {
            "de": "Welche Sprachen sprechen Sie?",
            "en": "What languages do you speak?"
          },
          {
            "de": "Ich spreche Bengalisch und Englisch.",
            "en": "I speak Bengali and English."
          },
          {
            "de": "Ich lerne Deutsch.",
            "en": "I am learning German."
          },
          {
            "de": "Ich spreche ein bisschen Deutsch.",
            "en": "I speak a little German."
          }
        ]
      }
    ],
    "tip": "<strong>টিপ:</strong> অপরিচিত, শিক্ষক বা বড়দের সাথে <em>Sie</em> (formal) ব্যবহার করুন। বন্ধু ও সহপাঠীদের সাথে <em>du</em> (informal) ব্যবহার করুন। Goethe A1 পরীক্ষায় উভয়ই আসতে পারে।",
    "tipEN": "<strong>Tip:</strong> Use <em>Sie</em> (formal) with strangers, teachers, and older people. Use <em>du</em> (informal) with friends and classmates. In the Goethe A1 exam, both may appear."
  },
